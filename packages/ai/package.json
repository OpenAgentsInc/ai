{
  "name": "@openagentsinc/ai",
  "version": "0.2.1-rc.2",
  "private": false,
  "description": "OpenAgents AI SDK umbrella package. Curated re-exports of the SDK layer entry points.",
  "license": "Apache-2.0",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./model": "./src/model.ts",
    "./schema": "./src/schema.ts",
    "./event-log": "./src/event-log.ts",
    "./sandbox": "./src/sandbox.ts",
    "./harness": "./src/harness.ts",
    "./ui-stream": "./src/ui-stream.ts",
    "./recall": "./src/recall.ts",
    "./rlm": "./src/rlm.ts",
    "./graph": "./src/graph.ts",
    "./graph/ranking": "./src/graph-ranking.ts",
    "./graph/archive": "./src/graph-archive.ts",
    "./conformance": "./src/conformance.ts",
    "./program": "./src/program.ts",
    "./program/contract": "./src/program-contract.ts",
    "./program/runtime": "./src/program-runtime.ts",
    "./program/optimizer": "./src/program-optimizer.ts",
    "./program/test": "./src/program-test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vp test --run packages/ai/src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openagentsinc/agent-harness-contract": "workspace:*",
    "@openagentsinc/agent-runtime-schema": "workspace:*",
    "@openagentsinc/ai-model": "workspace:*",
    "@openagentsinc/dse": "workspace:*",
    "@openagentsinc/graph-corpus": "workspace:*",
    "@openagentsinc/history-corpus": "workspace:*",
    "@openagentsinc/rlm": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@openagentsinc/conformance-kit": "workspace:*",
    "@types/node": "catalog:",
    "@types/vite-plus-matchers": "workspace:*",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@openagentsinc/conformance-kit": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@openagentsinc/conformance-kit": {
      "optional": true
    }
  }
}
