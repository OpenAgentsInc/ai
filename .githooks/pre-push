#!/usr/bin/env bash
# Pre-push guard for OpenAgentsInc/ai — local gates only (no GitHub Actions).
# Same posture as the openagents monorepo: enable with
#   git config core.hooksPath .githooks
#
# Guards only pushes whose remote ref is main.
set -uo pipefail

gate=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|*/main) gate=1 ;;
  esac
done

[ "$gate" = 1 ] || exit 0

root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$root" ] || [ ! -d "$root" ]; then
  echo "[pre-push] BLOCKED: could not resolve repository root" >&2
  exit 1
fi

cd "$root" || exit 1
echo "[pre-push] main push → running pnpm run check ..."
if ! pnpm run check; then
  echo "[pre-push] BLOCKED: pnpm run check failed" >&2
  exit 1
fi
echo "[pre-push] check green — push allowed."
exit 0
